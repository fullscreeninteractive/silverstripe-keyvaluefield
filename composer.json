{
    "name": "fullscreeninteractive/silverstripe-keyvaluefield",
    "description": "A Silverstripe FormField for extending TextField with several parts (keys)",
    "type": "silverstripe-vendormodule",
    "homepage": "http://silverstripe.org",
    "license": "BSD-3-Clause",
    "keywords": [
        "silverstripe",
        "versioned"
    ],
    "authors": [{
        "name": "Will Rossiter",
        "homepage": "http://www.fullscreen.io"
    }],
    "require": {
        "php": "^8.1",
        "silverstripe/framework": "^5",
        "silverstripe/vendor-plugin": "^2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3",
        "silverstripe/standards": "^1",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^2.1",
        "cambis/silverstan": "^2.1"
    },
    "suggest": {
        "silverstripe/userforms": "Adds EditableKeyValueField and submitted value display for user-defined forms"
    },
    "autoload": {
        "psr-4": {
            "FullscreenInteractive\\KeyValueField\\": "src/",
            "FullscreenInteractive\\KeyValueField\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "lint": [
            "@phpstan",
            "@phpcs"
        ],
        "lint:phpstan": "phpstan analyse -c phpstan.neon.dist --memory-limit=512M",
        "lint:phpcs": "phpcs",
        "phpstan": "@lint:phpstan",
        "phpcs": "@lint:phpcs",
        "phpcbf": "phpcbf",
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage"
    },
    "extra": {
        "expose": [
            "client"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "silverstripe/vendor-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
